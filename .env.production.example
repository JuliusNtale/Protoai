APP_DOMAIN=proctoaibackend.neuraltale.com
FRONTEND_URL=https://proctoai.neuraltale.com
EXISTING_NGINX_NETWORK=kreative-karakana-backend_karakana_net

POSTGRES_DB=proctoring_db
POSTGRES_USER=proctoring_user
POSTGRES_PASSWORD=replace-with-a-long-random-password

JWT_SECRET=replace-with-a-256-bit-random-secret
JWT_EXPIRY_HOURS=8
AI_SERVICE_TOKEN=replace-with-a-long-random-internal-token

EMAIL_MODE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@example.com
EMAIL_USE_TLS=true

ALLOW_PUBLIC_REGISTRATION=false
BOOTSTRAP_ADMIN_USERNAME=admin.temp
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_REG_NUMBER=ADM-BOOTSTRAP-001
BOOTSTRAP_ADMIN_PASSWORD=replace-before-first-start

FACENET_MODEL_VERSION=facenet_best.onnx
L2CS_MODEL_VERSION=l2cs_net.onnx
FACE_SIMILARITY_THRESHOLD=0.6
GAZE_AWAY_SECONDS=5
HEAD_TURNED_SECONDS=3
HEAD_YAW_THRESHOLD=30
HEAD_PITCH_THRESHOLD=20
