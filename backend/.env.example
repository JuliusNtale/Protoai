PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=proctoring_dev
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars
JWT_EXPIRY=8h

# Email (set EMAIL_MODE=dev to use Ethereal test inbox — no SMTP setup needed)
EMAIL_MODE=dev
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=onboarding@resend.dev

# Frontend URL used in password reset emails
APP_URL=http://localhost:3000

# Internal token shared with Flask AI service
AI_SERVICE_TOKEN=dev-internal-secret-change-in-prod

# Image storage path (relative to backend/)
STORAGE_PATH=./storage/faces
